# API server port（勿与 Vite 前端 3000 冲突）
PORT=3001

# 生产站点来源（逗号分隔多个）。未设置 = 开发模式允许所有来源
# 本地开发若已设置生产域名，请加上 localhost：
# CORS_ORIGIN=https://hockhoetong.com,http://localhost:3000
CORS_ORIGIN=

# Clinic contact (displayed on site)
CLINIC_PHONE=013-6268626
VITE_CLINIC_PHONE=013-6268626

# 页脚联系邮箱
VITE_CLINIC_EMAIL=hockhoetong1987@gmail.com

# 顾客点击电话 → WhatsApp（非 tel: 拨号）
VITE_WHATSAPP_URL=https://wa.me/qr/Z5GFCPPORNDIK1

# —— 店员后台 /admin ——
STAFF_USERNAME=admin
STAFF_PASSWORD=请设置强密码
ADMIN_SECRET=请设置一长串随机字符

# 休息日已改在店员后台 /admin →「休息」页设置（server/data/schedule.json）
# 以下仅作首次迁移用，可留空：
# OFF_WEEKDAYS=0
# OFF_DATES=2026-12-25

# Optional: override API base
# VITE_API_URL=http://localhost:3001

# SQLite database file (default: server/data/clinic.db)
# DB_PATH=server/data/clinic.db

# —— Vite 开发（经 hockhoetong.dpdns.org 等隧道访问时）——
# 关闭热更新 WebSocket，避免控制台 wss 报错；改 .env.local 后必须重启 npm run dev
DISABLE_HMR=true
# 若隧道已正确转发 WebSocket，可改为指定域名以启用 HMR：
# VITE_DEV_TUNNEL_HOST=hockhoetong.dpdns.org
# VITE_DEV_TUNNEL_PORT=443
