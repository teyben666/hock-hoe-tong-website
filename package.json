{
  "name": "hock-hoe-tong-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c magenta,cyan \"tsx watch server/index.ts\" \"node scripts/wait-for-api.mjs && vite --port=3000\"",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node scripts/start-prod.mjs",
    "prod": "npm run build && npm start",
    "start:api": "tsx server/index.ts",
    "db:migrate": "tsx scripts/migrate-json-to-sqlite.ts",
    "db:generate": "drizzle-kit generate",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.2",
    "express": "^4.21.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wait-on": "^9.0.10"
  }
}
